"@REF: https://gitee.com/mirrorvim/vim-fast/blob/master/vimrc-no-plug
"@REF: https://www.zhihu.com/question/26248191/answer/2575985121
"@REF: https://github.com/junegunn/vim-plug/wiki/tips

"Clipboard"
set clipboard^=unnamed,unnamedplus

"Disable Distributed Plugins"
let g:loaded_gzip=1
let g:loaded_tar=1
let g:loaded_tarPlugin=1
let g:loaded_zip=1
let g:loaded_zipPlugin=1
let g:loaded_getscript=1
let g:loaded_getscriptPlugin=1
let g:loaded_vimball=1
let g:loaded_vimballPlugin=1
let g:loaded_2html_plugin=1
let g:loaded_logiPat=1
let g:loaded_rrhelper=1
let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
let g:loaded_netrwSettings=1
let g:loaded_netrwFileHandlers=1
let g:loaded_matchit=1
let g:loaded_matchparen=1

"Options"
set novisualbell
set noerrorbells
set t_vb=
set nocompatible
set t_Co=256
set t_ut=
set notermguicolors
set number
set relativenumber
syntax on
filetype plugin indent on
set whichwrap=h,l,<,>,[,],~
set colorcolumn=80
set cursorline
set cursorlineopt=number
set cursorcolumn
set timeout
set timeoutlen=200
set ttimeout
set ttimeoutlen=100
set autoindent
set cindent
set smartindent
set expandtab
set softtabstop=2
set tabstop=2
set shiftwidth=2
set scrolloff=1
set sidescroll=1
set laststatus=2
set showtabline=2
set pumheight=12
set pumwidth=20
set showmatch
set matchtime=2
set display=lastline
set lazyredraw
set ruler
set splitright
set splitbelow
set nowrap
set hlsearch
set incsearch
set ignorecase
set smartcase
set nobackup
set noswapfile
set noundofile
set autoread
set wildmenu
set wildmode=list:longest,full
set showcmd
set backspace=eol,start,indent
set listchars=tab:»·,nbsp:+,trail:·,extends:→,precedes:←
set complete=.,w,b,u,t,i
set completeopt=menuone,longest,preview,noselect
set omnifunc=syntaxcomplete#Complete

"autocmd"
autocmd BufNewFile,BufRead * setlocal formatoptions-=cro
autocmd BufReadPre * if getfsize(expand("%")) > 1000000 | syntax clear | endif

"Keys"
let mapleader="\<Space>"
let maplocalleader=","
inoremap jk <Esc>
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

"Colorscheme"
set background=dark
colorscheme zaibatsu

"vim-plug"
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
        \ https://raw.github.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif
call plug#begin('~/.vim/plugged')
Plug 'itchyny/lightline.vim', {'on': []}
call plug#end()

"lightline.vim"
augroup lightline
  autocmd!
  autocmd BufReadPost * call plug#load('lightline.vim')
        \| autocmd! lightline
        \| let g:lightline = {'colorscheme': 'powerlineish'}
        \| call lightline#enable()
augroup END
