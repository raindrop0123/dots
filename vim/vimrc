" Clipboard
set clipboard^=unnamed,unnamedplus

" Disable Distributed Plugins
let g:loaded_gzip=1
let g:loaded_tar=1
let g:loaded_tarPlugin=1
let g:loaded_zip=1
let g:loaded_zipPlugin=1
let g:loaded_getscript=1
let g:loaded_getscriptPlugin=1
let g:loaded_vimball=1
let g:loaded_vimballPlugin=1
let g:loaded_2html_plugin=1
let g:loaded_logiPat=1
let g:loaded_rrhelper=1
let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
let g:loaded_netrwSettings=1
let g:loaded_netrwFileHandlers=1
let g:loaded_matchit=1
let g:loaded_matchparen=1

" Options
set novisualbell
set noerrorbells
set t_vb=
set nocompatible
set t_Co=256
set notermguicolors
set number
set relativenumber
syntax on
filetype plugin indent on
set whichwrap=h,l,<,>,[,],~
set colorcolumn=80
set cursorline
set cursorcolumn
set timeout
set timeoutlen=200
set ttimeout
set ttimeoutlen=100
set autoindent
set cindent
set smartindent
set expandtab
set softtabstop=2
set tabstop=2
set shiftwidth=2
set scrolloff=1
set sidescroll=1
set laststatus=2
set showtabline=2
set pumheight=12
set pumwidth=20
set showmatch
set matchtime=2
set display=lastline
set lazyredraw
set ruler
set splitright
set splitbelow
set nowrap
set hlsearch
set incsearch
set ignorecase
set smartcase
set nobackup
set noswapfile
set noundofile
set autoread
set wildmenu
set wildmode=list:longest,full
set showcmd
set backspace=eol,start,indent
set listchars=tab:»·,nbsp:+,trail:·,extends:→,precedes:←
set complete=.,w,b,u,t,i
set completeopt=menuone,longest,preview,noselect
set omnifunc=syntaxcomplete#Complete

" autocmd
autocmd BufNewFile,BufRead * setlocal formatoptions-=cro

" Keys
let mapleader="\<Space>"
let maplocalleader=","
inoremap jk <Esc>
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Colorscheme
set background=dark

" vim-plug
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs 
        \ https://raw.github.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif
call plug#begin('~/.vim/plugged')
Plug 'tpope/vim-commentary', {'on': []}
Plug 'andymass/vim-matchup', {'on': []}
Plug 'rhysd/clever-f.vim', {'on': []}
Plug 'justinmk/vim-sneak', {'on': []}
Plug 'terryma/vim-multiple-cursors', {'on': []}
Plug 'morhetz/gruvbox', {'on': []}
Plug 'dominikduda/vim_current_word', {'on': []}
Plug 'ap/vim-buftabline', {'on': []}
Plug 'ntpeters/vim-better-whitespace', {'on': []}
Plug 'sheerun/vim-polyglot', {'on': []}
Plug 'shinchu/lightline-gruvbox.vim', {'on': []}
Plug 'itchyny/lightline.vim', {'on': []}
Plug 'Yggdroot/indentLine', {'on': []}
Plug 'LunarWatcher/auto-pairs', {'on': []}
Plug 'ryanoasis/vim-devicons', {'on': []}
Plug 'machakann/vim-highlightedyank', {'on': []}
Plug 'luochen1990/rainbow', {'on': []}
Plug 'airblade/vim-gitgutter', {'on': []}
Plug 'chrisbra/Colorizer', {'on': []}
Plug 'dense-analysis/ale', {'on': []}
Plug 'liuchengxu/vista.vim', {'on': ['Vista']}
Plug 'easymotion/vim-easymotion', {'on': ['<Plug>(easymotion-bd-jk)', '<Plug>(easymotion-bd-w)']}
Plug 'preservim/nerdtree', {'on': ['NERDTreeToggle']}
Plug 'junegunn/fzf', {'do': {-> fzf#install()}}
Plug 'junegunn/fzf.vim', {'on': ['Files', 'Buffers', 'Rg', 'Lines', 'BLines']}
Plug 'liuchengxu/vim-which-key', {'on': ['WhichKey', 'WhichKey!']}
Plug 'voldikss/vim-floaterm', {'on': ['FloatermToggle', 'FloatermNew']}
Plug 'prabirshrestha/asyncomplete.vim', {'on': []}
Plug 'prabirshrestha/asyncomplete-file.vim', {'on': []}
Plug 'prabirshrestha/asyncomplete-buffer.vim', {'on': []}
Plug 'prabirshrestha/asyncomplete-lsp.vim', {'on': []}
Plug 'prabirshrestha/vim-lsp', {'on': []}
Plug 'mattn/vim-lsp-settings', {'on': ['LspInstallServer']}
call plug#end()

" vim-commentary
augroup commentary
  autocmd!
  autocmd BufReadPost * call plug#load('vim-commentary')
        \| autocmd! commentary
augroup END

" vim-matchup
augroup vim_matchup
  autocmd!
  autocmd BufReadPost * call plug#load('vim-matchup')
        \| autocmd! vim_matchup
augroup END

" gruvbox
augroup gruvbox
  autocmd!
  autocmd BufReadPost * call plug#load('gruvbox')
        \| autocmd! gruvbox
        \| colorscheme gruvbox
augroup END

" vim-buftabline
augroup buftabline
  autocmd!
  autocmd BufReadPost * call plug#load('vim-buftabline')
        \| autocmd! buftabline
augroup END

" lightline.vim
" lightline-gruvbox.vim
augroup lightline
  autocmd!
  autocmd BufReadPost * call plug#load('lightline-gruvbox.vim', 'lightline.vim')
        \| autocmd! lightline
        \| let g:lightline = {'colorscheme': 'gruvbox'}
        \| call lightline#enable()
augroup END

" indentLine
augroup indentline
  autocmd!
  autocmd BufReadPost * call plug#load('indentLine')
        \| autocmd! indentline
        \| let g:indentLine_char='c'
        \| let g:indentLine_char_list=['│'] " '|', '¦', '┆', '┊'
        \| indentLineToggle
augroup END

" auto-pairs
augroup auto_pairs
  autocmd!
  autocmd InsertEnter * call plug#load('auto-pairs')
        \| autocmd! auto_pairs
        \| call autopairs#AutoPairsTryInit()
augroup END

" vim-devicons
augroup devicons
  autocmd!
  autocmd BufReadPost * call plug#load('vim-devicons')
        \| autocmd! devicons
augroup END

" rainbow
let g:rainbow_active=1
augroup rainbow
  autocmd!
  autocmd InsertEnter * call plug#load('rainbow')
        \| autocmd! rainbow
augroup END

" Colorizer
augroup colorizer
  autocmd!
  autocmd BufReadPost * call plug#load('Colorizer')
        \| autocmd! colorizer
        \| ColorToggle
augroup END

" vim_current_word
augroup current_word
  autocmd!
  autocmd CursorMoved,CursorMovedI * call plug#load('vim_current_word')
        \| autocmd! current_word
        \| call vim_current_word#vim_current_word_enable()
augroup END

" vim-better-whitespace
augroup whitespace
  autocmd!
  autocmd InsertEnter * call plug#load('vim-better-whitespace')
        \| autocmd! whitespace
augroup END

" vim-polyglot
augroup vim_polyglot
  autocmd!
  autocmd InsertEnter * call plug#load('vim-polyglot')
        \| autocmd! vim_polyglot
augroup END

" vim-highlightedyank
augroup vim_highlightedyank
  autocmd!
  autocmd BufReadPost * call plug#load('vim-highlightedyank')
        \| autocmd! vim_highlightedyank
augroup END

" vim-gitgutter
augroup gitgutter
  autocmd!
  autocmd InsertEnter * call plug#load('vim-gitgutter')
        \| autocmd! gitgutter
        \| call gitgutter#enable()
augroup END

" vim-easymotion
map <leader><leader><leader>l <Plug>(easymotion-bd-jk)
map <leader><leader><leader>j <Plug>(easymotion-bd-w)

" nerdtree
let NERDTreeShowHidden=1
nnoremap <F1> <Cmd>NERDTreeToggle<CR>

" fzf.vim
nnoremap <leader>fb <Cmd>Buffers<CR>
nnoremap <leader>fF <Cmd>Files ~/<CR>
nnoremap <leader>ff <Cmd>Files<CR>
nnoremap <leader>fw <Cmd>Rg<CR>
nnoremap <C-s> <Cmd>BLines<CR>

" vim-which-key
nnoremap <silent> <leader> :<c-u>WhichKey '<Space>'<CR>
nnoremap <silent> <localleader> :<c-u>WhichKey ','<CR>

" vim-floaterm
nnoremap <silent> <F12> :FloatermToggle<CR>
tnoremap <silent> <F12> <C-\><C-n>:FloatermToggle<CR>

" ale
let g:ale_completion_enabled = 1
augroup ale
  autocmd!
  autocmd InsertEnter * call plug#load('ale')
        \| autocmd! ale
augroup END

" asyncomplete.vim
" asyncomplete-buffer.vim
" asyncomplete-file.vim
" asyncomplete-lsp.vim
inoremap <expr> <cr> pumvisible() ? asyncomplete#close_popup() : "\<cr>"
augroup load_asyncomplete
  autocmd!
  autocmd InsertEnter * call plug#load('asyncomplete.vim', 'asyncomplete-file.vim', 'asyncomplete-buffer.vim', 'asyncomplete-lsp.vim')
        \| autocmd! load_asyncomplete
        \| call asyncomplete#enable_for_buffer()
augroup END

autocmd User asyncomplete_setup call asyncomplete#register_source(asyncomplete#sources#buffer#get_source_options({
      \ 'name': 'Buffer',
      \ 'whitelist': ['*'],
      \ 'blacklist': ['go'],
      \ 'completor': function('asyncomplete#sources#buffer#completor'),
      \ }))

autocmd User asyncomplete_setup call asyncomplete#register_source(asyncomplete#sources#file#get_source_options({
      \ 'name': 'File',
      \ 'allowlist': ['*'],
      \ 'priority': 10,
      \ 'completor': function('asyncomplete#sources#file#completor'),
      \ }))

" vim-lsp
function! s:on_lsp_buffer_enabled() abort
  setlocal omnifunc=lsp#complete
  setlocal signcolumn=yes
  if exists('+tagfunc') | setlocal tagfunc=lsp#tagfunc | endif
  nmap <buffer> gd <plug>(lsp-definition)
  nmap <buffer> gs <plug>(lsp-document-symbol-search)
  nmap <buffer> gS <plug>(lsp-workspace-symbol-search)
  nmap <buffer> gr <plug>(lsp-references)
  nmap <buffer> gi <plug>(lsp-implementation)
  nmap <buffer> gt <plug>(lsp-type-definition)
  nmap <buffer> <leader>rn <plug>(lsp-rename)
  nmap <buffer> [g <plug>(lsp-previous-diagnostic)
  nmap <buffer> ]g <plug>(lsp-next-diagnostic)
  nmap <buffer> K <plug>(lsp-hover)
  nnoremap <buffer> <expr><c-f> lsp#scroll(+4)
  nnoremap <buffer> <expr><c-d> lsp#scroll(-4)
  let g:lsp_format_sync_timeout = 1000
  autocmd! BufWritePre *.rs,*.go call execute('LspDocumentFormatSync')
endfunction

augroup vim_lsp
  autocmd!
  autocmd InsertEnter * call plug#load('vim-lsp')
        \| autocmd! vim_lsp
        \| call lsp#enable()
augroup END

augroup lsp_install
  autocmd!
  " call s:on_lsp_buffer_enabled only for languages that has the server registered.
  autocmd User lsp_buffer_enabled call s:on_lsp_buffer_enabled()
augroup END

if executable('clangd')
  autocmd User lsp_setup call lsp#register_server({
        \ 'name': 'clangd',
        \ 'cmd': {server_info->['clangd', '-background-index']},
        \ 'whitelist': ['c', 'cpp', 'objc', 'objcpp'],
        \ })
endif
