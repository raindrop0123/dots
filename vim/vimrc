  Plug 'prabirshrestha/vim-lsp', {'on': []}
  Plug 'mattn/vim-lsp-settings', {'on': ['LspInstallServer']}
call plug#end()

""UI

"catppuccin
augroup catppuccin
  autocmd!
  autocmd BufReadPost * call plug#load('vim')
        \| autocmd! catppuccin
        \| colorscheme catppuccin_mocha
        \| highlight Normal guibg=#11111b guifg=#cdd6f4
        \| highlight Comment guifg=#9399b2
        \| highlight CursorLineNr guifg=#a6e3a1
        \| highlight Pmenu guibg=#181825 guifg=#cdd6f4
        \| highlight PmenuSel guibg=#89b4fa guifg=#11111b
augroup END

"lightline.vim
augroup lightline
  autocmd!
  autocmd BufReadPost * call plug#load('lightline.vim')
        \| autocmd! lightline
        \| let g:lightline = {'colorscheme': 'catppuccin_mocha'}
        \| call lightline#enable()
augroup END

"vim-buftabline
augroup buftabline
  autocmd!
  autocmd BufReadPost * call plug#load('vim-buftabline')
        \| autocmd! buftabline
augroup END

"indentLine
augroup indentline
  autocmd!
