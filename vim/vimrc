" 禁用內置插件
let g:loaded_gzip=1
let g:loaded_tar=1
let g:loaded_tarPlugin=1
let g:loaded_zip=1
let g:loaded_zipPlugin=1
let g:loaded_getscript=1 
let g:loaded_getscriptPlugin=1
let g:loaded_vimball=1
let g:loaded_vimballPlugin=1
let g:loaded_2html_plugin=1
let g:loaded_logiPat=1
let g:loaded_rrhelper=1
let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
let g:loaded_netrwSettings=1
let g:loaded_netrwFileHandlers=1
" let g:loaded_matchit=1
" let g:loaded_matchparen=1

" 禁止鈴聲改用螢幕閃爍提醒
set noeb
set vb t_vb=

" 不與vi兼容
set nocompatible

" 終端顏色與深色背景
set termguicolors
set background=dark

" 使用系統剪貼板
set clipboard^=unnamed,unnamedplus

" 行號與相對行號
set number
set relativenumber

" 語法高亮開啟
syntax on

" 插件及縮進根據文件類型開啟
filetype plugin indent on

" 遇到以下符號自動換行
set whichwrap=h,l,<,>,[,],~

" 在80行設置一條線
set colorcolumn=80

" 高亮光標所在的行列
set cursorline
set cursorcolumn

" 超時功能檢測
set timeout
set timeoutlen=200
set ttimeout
set ttimeoutlen=100

" 自動縮進
set autoindent

" 開啟c/c++縮進優化
set cindent

" 設定1 TAB = 2 Space
set expandtab
set tabstop=2
set softtabstop=2
set shiftwidth=2

" UI
set scrolloff=1
set sidescroll=1
set laststatus=2
set showtabline=2

" pmenu設定
set pumheight=12

" 顯示匹配的括號
set showmatch
set matchtime=2

" 顯示最後一行
set display=lastline

" 延遲繪製以提升性能
set lazyredraw

" 顯示光標所在的坐標
set ruler

" 切分視窗總是在右邊與下面
set splitright
set splitbelow

" 關閉自動摺行
set nowrap

" 高亮搜索內容
set hlsearch

" 增量搜索結果
set incsearch

" 搜索忽略大小寫
set ignorecase

" 預設忽略大小寫，除非搜索的文字中含有大寫字母
set smartcase

" 禁用備份文件、交換文件、undo文件
set nobackup
set noswapfile
set noundofile

" 當文件在其他地方被編輯，vim自動重新讀取 
set autoread

" wildmenu
set wildmenu
set wildmode=longest:list,full

" 右下角顯示命令
set showcmd

" 設定Backspace模式
set backspace=eol,start,indent

" Leader and Local Leader
let mapleader="\<Space>"
let maplocalleader=","

" 用jk代替Esc
inoremap jk <Esc>

" 快速切換視窗
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" 根據文件類型微調設定
augroup FileTypeSetup

  " 清除同組的歷史自動命令
  autocmd!

  " c/c++使用//當作註釋
  autocmd FileType c,cpp setlocal commentstring=//\ %s

  " python使用4個空白當作縮進
  autocmd FileType python setlocal tabstop=4 shiftwidth=4

  " quickfix隱藏行號
  autocmd FileType qf setlocal nonumber

augroup END

" 安裝插件管理器vim-plug
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs 
        \ https://raw.github.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif
nnoremap <leader>pl <Cmd>PlugInstall<CR>

