nnoremap <leader>fF <Cmd>Files<CR>
nnoremap <leader>fs <Cmd>Lines<CR>
nnoremap <leader>fS <Cmd>BLines<CR>
nnoremap <leader>fw <Cmd>Rg<CR>

" vim-floaterm
nnoremap <silent> <leader>tt :FloatermNew --width=0.9 --height=0.88<CR>
tnoremap <silent> <leader>tt <C-\><C-n>:FloatermNew<CR>
nnoremap <silent> <leader>tp :FloatermPrev<CR>
tnoremap <silent> <leader>tp <C-\><C-n>:FloatermPrev<CR>
nnoremap <silent> <leader>tn :FloatermNext<CR>
tnoremap <silent> <leader>tn <C-\><C-n>:FloatermNext<CR>
nnoremap <silent> <leader>tT :FloatermToggle<CR>
tnoremap <silent> <leader>tT <C-\><C-n>:FloatermToggle<CR>

" NerdTree
let NERDTreeShowHidden=1
nnoremap <leader>pn <Cmd>NERDTreeToggle<CR>

" vista.vim
