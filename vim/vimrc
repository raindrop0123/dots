"""Basic"""
let g:loaded_gzip=1                                " disable built-in plugins
let g:loaded_tar=1
let g:loaded_tarPlugin=1
let g:loaded_zip=1
let g:loaded_zipPlugin=1
let g:loaded_getscript=1
let g:loaded_getscriptPlugin=1
let g:loaded_vimball=1
let g:loaded_vimballPlugin=1
let g:loaded_matchit=0
let g:loaded_matchparen=0
let g:loaded_2html_plugin=1
let g:loaded_logiPat=1
let g:loaded_rrhelper=1
let g:loaded_netrw=1
let g:loaded_netrwPlugin=1
let g:loaded_netrwSettings=1
let g:loaded_netrwFileHandlers=1
set nocompatible                                   " Do not allow compatible with vi
set number                                         " show row number
set relativenumber                                 " show relative number
set colorcolumn=80                                 " show wrap line
set clipboard^=unnamed,unnamedplus                 " clipboard setup
set whichwrap=h,l,<,>,[,],~                        " wrap rule
set background=dark                                " background
set cursorline                                     " highlight the line
set cursorcolumn                                   " highlight the vertical line
syntax on                                          " turn on syntax highlight
filetype plugin indent on                          " set indent with specific filetype
set backspace=indent,eol,start                     " set backspace behavior
set showcmd                                        " show the current command
set termguicolors                                  " enable true color support
set t_Co=256                                       " trun on 256 color support
set autoindent                                     " auto indent when go to next line
set expandtab                                      " use space replace tab
set tabstop=2                                      " 1 tab = 2 spaces
set softtabstop=2                                  " 1 tab = 2 spaces
set shiftwidth=2                                   " the char number when pressing >>, << or ==
set nowrap                                         " do not auto-wrap line
set scrolloff=2                                    " When scrolling vertically, the cursor's distance from the top/bottom
set laststatus=2                                   " show status bar
set showtabline=2                                  " show tabline
set ruler                                          " show the position of cursor in status bar
set noshowmatch                                    " auto highlight the other brackets
set hlsearch                                       " highlight search
set incsearch                                      " increase search
set ignorecase                                     " ignore case when searching
set smartcase                                      " For single uppercase letter search queries, make it case-sensitive.
set nobackup                                       " disable backup file
set noswapfile                                     " disable to generate .swp file
set noundofile                                     " disable to generate undo history
set visualbell                                     " flashing monitor when error occurring
set autoread                                       " hint when this file is edited
set listchars=tab:»»,trail:■                       " set symbol of tab and space at the end of line
set wildmenu
set wildmode=longest:list,full                     " completion menu of command
set splitright                                     " split window always on right
set splitbelow                                     " split window always on bottom
set sidescroll=1
set completeopt=menuone,noinsert,noselect,preview  " complete options
set previewpopup=height:12,width:60                " set width and height of menu
set pumwidth=10                                    " width of Pmenu
set pumheight=15                                   " height of Pmenu
let mapleader=" "                                  " use space as leader key
let maplocalleader=","                             " use comma as local leader key
inoremap jk <Esc>
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

"""vim-plug"""
if empty(glob('~/.vim/autoload/plug.vim'))
  silent execute '!curl -fLo ~/.vim/autoload/plug.vim --create-dirs  https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
endif
nnoremap <leader>pl :PlugInstall<CR>

call plug#begin("~/.vim/plugged")
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
Plug 'andymass/vim-matchup'
Plug 'danilamihailov/beacon.nvim', {'on': []}
Plug 'catppuccin/vim', {'on': []}
Plug 'itchyny/lightline.vim', {'on': []}
Plug 'raimondi/delimitMate', {'on': []}
Plug 'luochen1990/rainbow', {'on': []}
Plug 'Yggdroot/indentLine', {'on': []}
Plug 'airblade/vim-gitgutter', {'on': []}
Plug 'dyng/ctrlsf.vim', {'on': []}
Plug 'junegunn/fzf.vim', {'on': ['Files', 'Buffers', 'Rg', 'Lines', 'BLines']}
Plug 'preservim/nerdtree', {'on': ['NERDTreeToggle']}
Plug 'easymotion/vim-easymotion', {'on': ['<Plug>(easymotion-bd-w)', '<Plug>(easymotion-bd-jk)']}
Plug 'liuchengxu/vim-which-key', {'on': ['WhichKey', 'WhichKey!']}
Plug 'voldikss/vim-floaterm', {'on': ['FloatermToggle']}
" Plug 'neoclide/coc.nvim', {'branch': 'release', 'on': []}
call plug#end()

"beacon.nvim"
augroup load_beacon
  autocmd!
  autocmd InsertEnter * call plug#load('beacon.nvim')
        \| autocmd! load_beacon
augroup END

"catppuccin"
augroup load_catppuccin
  autocmd!
  autocmd InsertEnter * call plug#load('vim')
        \| autocmd! load_catppuccin
        \| colorscheme catppuccin_mocha
        \| highlight Normal guibg=#11111b
        \| highlight Comment guifg=#7f849c
        \| highlight CursorLineNr guifg=#a6e3a1
        \| highlight Pmenu guifg=#cdd6f4
        \| highlight PmenuSel guibg=#a6e3a1 guifg=#11111b
augroup END

"lightline.vim"
augroup load_lightline
  autocmd!
  autocmd InsertEnter * call plug#load('lightline.vim')
        \| autocmd! load_lightline
        \| let g:lightline = {'colorscheme': 'catppuccin_mocha'}
        \| call lightline#enable()
augroup END

"delimitMate"
augroup load_delimitmate
  autocmd!
  autocmd InsertEnter * call plug#load('delimitMate')
        \| autocmd! load_delimitmate
augroup END

"rainbow"
augroup load_rainbow
  autocmd!
  autocmd InsertEnter * call plug#load('rainbow')
        \| autocmd! load_rainbow
        \| let g:rainbow_conf = {'guifgs': ['#f38ba8', '#fab387', '#f9e2af', '#a6e3a1', '#89dceb', '#89b4fa', '#cba6f7', '#b4befe']}
        \| call rainbow_main#toggle()
augroup END

"indentLine"
augroup load_indentline
  autocmd!
  autocmd InsertEnter * call plug#load('indentLine')
        \| autocmd! load_indentline
        \| let g:indentLine_char = 'c'
        \| let g:indentLine_char_list = ['|', '¦', '┆', '┊']
        \| IndentLinesToggle
augroup END

"vim-gitgutter"
augroup load_gitgutter
  autocmd!
  autocmd InsertEnter * call plug#load('vim-gitgutter')
        \| autocmd! load_gitgutter
        \| call gitgutter#enable()
augroup END

"ctrlsf.vim"
augroup load_ctrlsf
  autocmd!
  autocmd CmdlineEnter * call plug#load('ctrlsf.vim')
        \| autocmd! load_ctrlsf
augroup END

"NERDTree"
let NERDTreeShowHidden = 1
nnoremap <leader>pn <Cmd>NERDTreeToggle<CR>

"vim-easymotion"
let g:EasyMotion_do_mapping = 0
nnoremap <leader>W <Plug>(easymotion-bd-w)
nnoremap <leader>L <Plug>(easymotion-bd-jk)

"which-key"
let g:mapleader="\<Space>"
let g:maplocalleader=','
nnoremap <silent> <leader> :<c-u>WhichKey '<Space>'<CR>
nnoremap <silent> <localleader> :<c-u>WhichKey ','<CR>

"vim-floaterm"
nnoremap <silent> <leader>tf <Cmd>FloatermToggle<CR>
tnoremap <silent> <leader>tf <C-\><C-n>:FloatermToggle<CR>

"FZF"
let g:fzf_layout = {'down': '30%'}
nnoremap <leader>fb <Cmd>Buffers<CR>
nnoremap <leader>ff <Cmd>Files ~/<CR>
nnoremap <leader>fF <Cmd>Files<CR>
nnoremap <leader>fs <Cmd>Lines<CR>
nnoremap <leader>fS <Cmd>BLines<CR>
nnoremap <leader>fw <Cmd>Rg<CR>

