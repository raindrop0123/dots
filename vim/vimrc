"""Options
set novisualbell
set noerrorbells
set t_vb=
set nocompatible
set t_Co=256
set termguicolors
set number
set relativenumber
syntax on
filetype plugin indent on
set whichwrap=h,l,<,>,[,],~
set colorcolumn=80
set cursorline
set cursorcolumn
set timeout
set timeoutlen=200
set ttimeout
set ttimeoutlen=100
set autoindent
set cindent
set smartindent
set expandtab
set softtabstop=2
set tabstop=2
set shiftwidth=2
set scrolloff=1
set sidescroll=1
set laststatus=2
set showtabline=2
set pumheight=12
set pumwidth=20
set showmatch
set matchtime=2
set display=lastline
set lazyredraw
set ruler
set splitright
set splitbelow
set nowrap
set hlsearch
set incsearch
set ignorecase
set smartcase
set nobackup
set noswapfile
set noundofile
set autoread
set wildmenu
set wildmode=list:longest,full
set showcmd
set backspace=eol,start,indent
set listchars=tab:»·,nbsp:+,trail:·,extends:→,precedes:←
set complete=.,w,b,u,t,i
set completeopt=menuone,longest,preview,noselect
set omnifunc=syntaxcomplete#Complete

"""autocmd
autocmd BufNewFile,BufRead * setlocal formatoptions-=cro

"""Keys
let mapleader="\<Space>"
let maplocalleader=","
inoremap jk <Esc>
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

"""Colorscheme
set background=dark

"""vim-plug
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
        \ https://raw.github.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

call plug#begin('~/.vim/plugged')
  ""UI
  Plug 'catppuccin/vim', {'on': []}
  Plug 'itchyny/lightline.vim', {'on': []}
  Plug 'ap/vim-buftabline', {'on': []}
  Plug 'Yggdroot/indentLine', {'on': []}
  Plug 'airblade/vim-gitgutter', {'on': []}
  Plug 'ryanoasis/vim-devicons', {'on': []}
  ""EDITOR
  Plug 'LunarWatcher/auto-pairs', {'on': []}
  Plug 'luochen1990/rainbow', {'on': []}
  Plug 'tpope/vim-commentary', {'on': []}
  Plug 'andymass/vim-matchup', {'on': []}
  Plug 'dominikduda/vim_current_word', {'on': []}
  Plug 'ntpeters/vim-better-whitespace', {'on': []}
  Plug 'machakann/vim-highlightedyank', {'on': []}
  Plug 'sheerun/vim-polyglot', {'on': []}
  Plug 'dense-analysis/ale', {'on': []}
  Plug 'chrisbra/Colorizer', {'on': []}
  Plug 'liuchengxu/vim-which-key', {'on': ['WhichKey', 'WhichKey!']}
  ""TOOL
  Plug 'preservim/nerdtree', {'on': ['NERDTreeToggle']}
  Plug 'junegunn/fzf', {'do': {-> fzf#install()}}
  Plug 'junegunn/fzf.vim', {'on': ['Files', 'Buffers', 'Rg', 'Lines', 'BLines']}
  Plug 'voldikss/vim-floaterm', {'on': ['FloatermToggle', 'FloatermNew']}
