        \| autocmd! indentline
        \| let g:indentLine_char='c'
        \| let g:indentLine_char_list=['│', '|', '¦', '┆', '┊']
        \| IndentLinesToggle
augroup END

"vim-gitgutter
augroup vim_gitgutter
